<assembly xmlns="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/plugins/maven-assembly-plugin/assembly/1.1.2 http://maven.apache.org/xsd/assembly-1.1.2.xsd">

    <id>distribution</id>

    <formats>
        <format>zip</format>
    </formats>

    <dependencySets>
        <dependencySet>
            <outputDirectory>/lib</outputDirectory>
        </dependencySet>
    </dependencySets>

    <fileSets>
        <fileSet>
            <directory>${project.basedir}/../auslieferung</directory>
            <includes>
                <include>Creditreform.png</include>
                <include>ENE-config.properties</include>
                <include>ENE-PG-config.properties</include>
                <include>GEE-config.properties</include>
                <include>ABE-config.properties</include>
                <include>REE-config.properties</include>
                <include>log4j.properties</include>
                <include>tesun.cmd</include>
                <include>TestSupport-GUI.cmd</include>
                <include>auto_cte_tests.cmd</include>
                <include>auto_cte_tests.sh</include>
                <include>LogSearch-GUI.cmd</include>
                <include>XmlSearch-GUI.cmd</include>
                <include>XmlSearch-GUI.sh</include>
                <include>CompareXmlExports.cmd</include>
                <include>TestUtils.doc</include>
                <include>XML-Such Util.doc</include>
                <include>gee_searchitems.properties</include>
                <include>cte_private_key_lieferant.asc</include>
            </includes>
            <outputDirectory>/</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/../auslieferung/search_criterias</directory>
            <outputDirectory>/search_criterias</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/../auslieferung/lookandfeels</directory>
            <includes>
                <include>*.jar</include>
            </includes>
            <outputDirectory>/lib</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${project.basedir}/../auslieferung/Diff-Tools</directory>
            <outputDirectory>/Diff-Tools</outputDirectory>
        </fileSet>

        <fileSet>
            <directory>${project.build.directory}/buildinfo-template</directory>
            <includes>
                <include>buildinfo.properties</include>
            </includes>
            <outputDirectory>/lib</outputDirectory>
        </fileSet>

        <!-- Entpackte Testfaelle aus Projektverzeichnis einbinden -->
        <fileSet>
            <directory>${testfaelle.unpacked-dir}</directory>
            <outputDirectory>/TESTS/ITSQ</outputDirectory>
            <includes>
                <include>**/*</include>
            </includes>
        </fileSet>
    </fileSets>

</assembly>
